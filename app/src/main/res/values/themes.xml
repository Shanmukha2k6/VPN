<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ShieldFox" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowBackground">#EEF2FF</item>
    </style>

    <style name="Theme.ShieldFox.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#EEF2FF</item>
        <item name="windowSplashScreenAnimatedIcon">@android:color/transparent</item>
        <item name="postSplashScreenTheme">@style/Theme.ShieldFox</item>
    </style>
</resources>
